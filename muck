#!/usr/bin/env bash
set -euo pipefail

VERSION="1.1.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_CSS_LIGHT="$SCRIPT_DIR/muck-light.min.css"
DEFAULT_CSS_DARK="$SCRIPT_DIR/muck-dark.min.css"
DEFAULT_CSS_DYNAMIC="$SCRIPT_DIR/muck-dynamic.min.css"
DEFAULT_CSS_NAV="$SCRIPT_DIR/muck-nav.css"
DEFAULT_JS_NAV="$SCRIPT_DIR/muck-nav.js"


help() {
  cat <<'EOF'
muck — convert Markdown to styled HTML or PDF

Usage:
  muck -i <input.md>... [-o <output>] [options]

Options:
  -i, --input <file|dir>     Input Markdown file or directory (required,
                            repeatable). Directories are expanded to all
                            .md files within them.
  -o, --output <file|dir>   Output file (.html or .pdf) or directory (with
                            trailing /). Defaults to input filename with
                            .html (or .pdf with --pdf-engine).
  -s, --stylesheet <file>   Inline a CSS file into the document (repeatable)
  --style-link [file|url]   Link a stylesheet instead of inlining (repeatable).
                            Local files are copied to an output folder.
  --script <file>           Inline a JavaScript file into the document
                            (repeatable)
  --script-link <file|url>  Link a JavaScript file or URL. Local files are
                            copied to an output folder. (repeatable)
  --pdf-engine <engine>     Generate PDF using the specified engine
                            (default: weasyprint)
  --page-size <size>        PDF page size (default: letter)
  --margin <margin>         PDF page margin (default: 1in)
  -c, --config <file>       Use a specific config file. Defaults to
                            ./muck.config, then ~/.muck/config
  --theme <name>            Apply a theme (default: dynamic). Built-in:
                            light, dark, dynamic, nav, none.
                            Custom themes defined in config [themes] section.
  --filename-transform <t>  Transform the output filename (repeatable).
                            Presets: lowercase, kebab, snake.
                            Also accepts a sed expression or a custom
                            transform name defined in the config file.
  --no-rewrite-links        Don't rewrite .md links to .html in output
  --keep-theme              Keep the default theme when -s/--style-link is used
  --mirror-structure        When outputting to a directory, preserve the input
                            directory structure in the output
  -h, --help                Show this help message
  --version                 Show version

Config File:
  muck reads a config file (one option per line) before processing CLI args,
  so CLI args always override config values. Example muck.config:

    --stylesheet ./theme.css
    --page-size A4
    --margin 2cm

  [scripts] section — scripts applied to every conversion:

    [scripts]
    ./analytics.js
    link:./app.js
    https://cdn.example.com/lib.js

  Each line is a file path (inlined) or URL (linked). Prefix with link: to
  force linking a local file instead of inlining it.

  [themes] section — custom themes with stylesheets and/or scripts:

    [themes]
    dracula https://cdn.example.com/dracula.css
    fancy ./style.css ./extra.css script:./toggle.js script-link:https://cdn.example.com/lib.js

  Each line starts with a theme name followed by space-separated assets.
  Unprefixed paths/URLs are stylesheets. script: inlines a JS file.
  script-link: links a JS file or URL. Multiple assets of each type are
  supported and applied in order.

Examples:
  muck -i notes.md                              # HTML with inline styles
  muck -i notes.md -s ./theme.css               # Custom stylesheet
  muck -i notes.md --style-link https://cdn.example.com/style.css  # Link stylesheet
  muck -i notes.md -o report.pdf                 # PDF via weasyprint
  muck -i notes.md -o report.pdf --page-size A4  # PDF with A4 pages
  muck -i ch1.md -i ch2.md -i ch3.md            # Convert multiple files
  muck -i ~/docs/*.md                            # Convert all .md files in a dir
  muck -i ~/docs/*.md -o ./output/               # Output all to a directory
  muck -i ~/docs/ -o ./output/ --mirror-structure # Preserve directory structure
  muck -i ./docs/ -o ./output/ --mirror-structure --theme nav  # Sidebar nav
EOF
  exit 0
}

# Find config file: check --config flag first, then defaults
config_file=""
for ((i=1; i<=$#; i++)); do
  if [[ "${!i}" == "--config" || "${!i}" == "-c" ]]; then
    j=$((i+1)); config_file="${!j}"; break
  fi
done
if [[ -z "$config_file" ]]; then
  if [[ -f "./muck.config" ]]; then config_file="./muck.config"
  elif [[ -f "$HOME/.muck/config" ]]; then config_file="$HOME/.muck/config"
  fi
fi

# Load config: parse [themes] and [filename-transforms] sections separately, rest becomes default args
theme_names=(light dark dynamic none nav)
theme_styles=("inline:$DEFAULT_CSS_LIGHT" "inline:$DEFAULT_CSS_DARK" "inline:$DEFAULT_CSS_DYNAMIC" "" "inline:$DEFAULT_CSS_DYNAMIC inline:$DEFAULT_CSS_NAV")
theme_scripts=("" "" "" "" "inline:$DEFAULT_JS_NAV")
custom_transform_names=()
custom_transform_exprs=()
config_scripts=()
config_args=()
if [[ -n "$config_file" && -f "$config_file" ]]; then
  config_dir="$(cd "$(dirname "$config_file")" && pwd)"
  in_section=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"          # strip comments
    [[ -z "${line// }" ]] && continue
    if [[ "$line" =~ ^\[themes\] ]]; then in_section=themes; continue; fi
    if [[ "$line" =~ ^\[filename-transforms\] ]]; then in_section=ft; continue; fi
    if [[ "$line" =~ ^\[scripts\] ]]; then in_section=scripts; continue; fi
    if [[ "$line" =~ ^\[ ]]; then in_section=""; fi
    if [[ "$in_section" == "themes" ]]; then
      read -r tname trest <<< "$line"
      if [[ -n "$tname" && -n "$trest" ]]; then
        tstyles=""; tscripts=""
        for asset in $trest; do
          if [[ "$asset" == script-link:* ]]; then
            ref="${asset#script-link:}"
            [[ "$ref" != /* && "$ref" != http* && -f "$config_dir/$ref" ]] && ref="$config_dir/$ref"
            tscripts+="${tscripts:+ }link:$ref"
          elif [[ "$asset" == script:* ]]; then
            ref="${asset#script:}"
            [[ "$ref" != /* && "$ref" != http* && -f "$config_dir/$ref" ]] && ref="$config_dir/$ref"
            tscripts+="${tscripts:+ }inline:$ref"
          else
            [[ "$asset" != /* && "$asset" != http* && -f "$config_dir/$asset" ]] && asset="$config_dir/$asset"
            if [[ -f "$asset" ]]; then tstyles+="${tstyles:+ }inline:$asset"
            else tstyles+="${tstyles:+ }link:$asset"; fi
          fi
        done
        theme_names+=("$tname")
        theme_styles+=("$tstyles")
        theme_scripts+=("$tscripts")
      fi
    elif [[ "$in_section" == "ft" ]]; then
      ftname="${line%% *}"
      ftexpr="${line#* }"
      if [[ -n "$ftname" && -n "$ftexpr" ]]; then
        custom_transform_names+=("$ftname")
        custom_transform_exprs+=("$ftexpr")
      fi
    elif [[ "$in_section" == "scripts" ]]; then
      # Resolve relative paths against config file directory
      val="$line"
      if [[ "$val" == link:* ]]; then
        ref="${val#link:}"
        [[ "$ref" != /* && "$ref" != http* && -f "$config_dir/$ref" ]] && ref="$config_dir/$ref"
        config_scripts+=("link:$ref")
      else
        [[ "$val" != /* && "$val" != http* && -f "$config_dir/$val" ]] && val="$config_dir/$val"
        config_scripts+=("inline:$val")
      fi
    else
      # shellcheck disable=SC2206
      config_args+=($line)
    fi
  done < "$config_file"
fi

# Merge: config args first, then CLI args (stripping --config from CLI)
cli_args=()
skip=false
for arg in "$@"; do
  if $skip; then skip=false; continue; fi
  if [[ "$arg" == "--config" || "$arg" == "-c" ]]; then skip=true; continue; fi
  cli_args+=("$arg")
done
set -- "${config_args[@]+"${config_args[@]}"}" "${cli_args[@]+"${cli_args[@]}"}"

# Ordered style entries: "inline:<path>" or "link:<file|url>"
styles=()
inputs=()
input_roots=()
scripts=("${config_scripts[@]+"${config_scripts[@]}"}")
filename_transforms=()
pdf_engine=""
page_size="letter"
page_margin="1in"
theme=""
output=""
rewrite_links=true
keep_theme=false
mirror_structure=false
while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help) help ;;
    --version) echo "muck $VERSION"; exit 0 ;;
    -i|--input) shift; while [[ $# -gt 0 && "$1" != -* ]]; do inputs+=("$1"); shift; done ;;
    -o|--output) output="$2"; shift 2 ;;
    -s|--stylesheet) styles+=("inline:$2"); shift 2 ;;
    --style-link)
      if [[ -n "${2:-}" && "$2" != -* ]]; then
        styles+=("link:$2"); shift 2
      else
        shift
      fi ;;
    --script) scripts+=("inline:$2"); shift 2 ;;
    --script-link) scripts+=("link:$2"); shift 2 ;;
    --pdf-engine) pdf_engine="$2"; shift 2 ;;
    --page-size) page_size="$2"; shift 2 ;;
    --margin) page_margin="$2"; shift 2 ;;
    --theme) theme="$2"; shift 2 ;;
    --filename-transform) filename_transforms+=("$2"); shift 2 ;;
    --no-rewrite-links) rewrite_links=false; shift ;;
    --keep-theme) keep_theme=true; shift ;;
    --mirror-structure) mirror_structure=true; shift ;;
    *) echo "Unknown option: $1" >&2; echo "Run 'muck --help' for usage." >&2; exit 1 ;;
  esac
done

[[ ${#inputs[@]} -eq 0 ]] && { echo "Error: -i <input.md> is required. Run 'muck --help' for usage." >&2; exit 1; }

# Expand directory inputs into .md files
expanded=()
for inp in "${inputs[@]}"; do
  if [[ -d "$inp" ]]; then
    abs_inp="$(cd "$inp" && pwd)"
    while IFS= read -r -d '' f; do
      expanded+=("$f")
      input_roots+=("$abs_inp")
    done < <(find "$inp" -name '*.md' -print0)
  else
    expanded+=("$inp")
    input_roots+=("")
  fi
done
inputs=("${expanded[@]}")
[[ ${#inputs[@]} -eq 0 ]] && { echo "Error: no .md files found in the specified directory." >&2; exit 1; }

# Determine if -o is a directory target
output_dir=""
if [[ -n "$output" ]]; then
  if [[ "$output" == */ || -d "$output" ]]; then
    output_dir="${output%/}"
    mkdir -p "$output_dir"
    output=""
  elif [[ ${#inputs[@]} -gt 1 ]]; then
    echo "Error: -o must be a directory (with trailing /) when used with multiple input files." >&2; exit 1
  fi
fi

# Default: apply theme, then any explicit styles on top
[[ -z "$theme" ]] && theme="dynamic"
theme_style=""
theme_script=""
theme_found=false
for ((i=0; i<${#theme_names[@]}; i++)); do
  if [[ "${theme_names[$i]}" == "$theme" ]]; then
    theme_style="${theme_styles[$i]}"
    theme_script="${theme_scripts[$i]}"
    theme_found=true
    break
  fi
done
if ! $theme_found; then
  echo "Error: unknown theme '$theme'. Available: ${theme_names[*]}" >&2; exit 1
fi
# Expand space-separated theme assets into arrays
theme_style_arr=()
[[ -n "$theme_style" ]] && read -ra theme_style_arr <<< "$theme_style"
theme_script_arr=()
[[ -n "$theme_script" ]] && read -ra theme_script_arr <<< "$theme_script"
if [[ ${#styles[@]} -eq 0 ]]; then
  styles=("${theme_style_arr[@]+"${theme_style_arr[@]}"}")
elif $keep_theme && [[ ${#theme_style_arr[@]} -gt 0 ]]; then
  styles=("${theme_style_arr[@]}" "${styles[@]}")
fi
if [[ ${#theme_script_arr[@]} -gt 0 ]]; then
  scripts=("${theme_script_arr[@]}" "${scripts[@]+"${scripts[@]}"}")
fi


# Build nav JSON tree (used by the nav theme)
# Produces a nested structure mirroring the output directory layout.
build_nav_json() {
  local _output_dir=$1
  local _mirror=$2
  shift 2
  # remaining args: interleaved src root src root ...
  local paths=()
  while [[ $# -gt 0 ]]; do
    local src="$1" root="$2"; shift 2
    if [[ "$_mirror" == true && -n "$root" ]]; then
      local abs_src rel
      abs_src="$(cd "$(dirname "$src")" && pwd)/$(basename "$src")"
      rel="${abs_src#$root/}"
      paths+=("${rel%.md}.html")
    else
      paths+=("$(basename "${src%.md}.html")")
    fi
  done

  python3 - "${paths[@]}" <<'PYEOF'
import sys, json, os
paths = sys.argv[1:]
def insert(tree, parts, full_path):
    if len(parts) == 1:
        tree.append({"label": os.path.splitext(parts[0])[0], "path": "/" + full_path})
    else:
        for node in tree:
            if node.get("label") == parts[0] and "children" in node:
                insert(node["children"], parts[1:], full_path)
                return
        node = {"label": parts[0], "children": []}
        tree.append(node)
        insert(node["children"], parts[1:], full_path)
root = []
for p in sorted(paths):
    insert(root, p.split("/"), p)
print(json.dumps(root))
PYEOF
}

nav_json=""
# Build nav JSON if the nav theme is active (muck-nav.js is in scripts)
for s in "${scripts[@]+"${scripts[@]}"}"; do
  if [[ "${s#*:}" == *muck-nav.js ]]; then
    # Interleave inputs and input_roots as positional args
    nav_args=()
    for ((i=0; i<${#inputs[@]}; i++)); do
      nav_args+=("${inputs[$i]}" "${input_roots[$i]:-}")
    done
    nav_json="$(build_nav_json "${output_dir:-}" "$mirror_structure" "${nav_args[@]}")"
    break
  fi
done

for ((input_idx=0; input_idx<${#inputs[@]}; input_idx++)); do
input="${inputs[$input_idx]}"
input_root="${input_roots[$input_idx]:-}"

case "${input##*.}" in
  md|markdown|mdown|mkd) ;;
  *) echo "⚠️  Skipping $(basename "$input") (not a Markdown file)" >&2; continue ;;
esac

[[ -f "$input" ]] || { echo "Error: $input not found" >&2; exit 1; }

if [[ -n "$output" ]]; then
  cur_output="$output"
elif [[ -n "$pdf_engine" ]]; then
  if $mirror_structure && [[ -n "$output_dir" && -n "$input_root" ]]; then
    abs_input="$(cd "$(dirname "$input")" && pwd)/$(basename "$input")"
    rel="${abs_input#$input_root/}"
    base="${rel%.*}.pdf"
  else
    base="$(basename "${input%.*}").pdf"
  fi
  cur_output="${output_dir:-$(dirname "$input")}/$base"
else
  if $mirror_structure && [[ -n "$output_dir" && -n "$input_root" ]]; then
    abs_input="$(cd "$(dirname "$input")" && pwd)/$(basename "$input")"
    rel="${abs_input#$input_root/}"
    base="${rel%.*}.html"
  else
    base="$(basename "${input%.*}").html"
  fi
  cur_output="${output_dir:-$(dirname "$input")}/$base"
fi

# Apply filename transforms to the output basename
if [[ ${#filename_transforms[@]} -gt 0 ]]; then
  out_dir_part="$(dirname "$cur_output")"
  out_base="$(basename "$cur_output")"
  out_ext="${out_base##*.}"
  out_name="${out_base%.*}"
  for t in "${filename_transforms[@]}"; do
    case "$t" in
      lowercase) out_name="$(echo "$out_name" | tr '[:upper:]' '[:lower:]')" ;;
      kebab) out_name="$(echo "$out_name" | sed 's/[_ ]/-/g')" ;;
      snake) out_name="$(echo "$out_name" | sed 's/[- ]/_/g')" ;;
      s*)  out_name="$(echo "$out_name" | sed "$t")" ;;
      *)
        matched=false
        for ((i=0; i<${#custom_transform_names[@]}; i++)); do
          if [[ "${custom_transform_names[$i]}" == "$t" ]]; then
            out_name="$(echo "$out_name" | sed "${custom_transform_exprs[$i]}")"
            matched=true; break
          fi
        done
        $matched || { echo "Error: unknown filename transform '$t'" >&2; exit 1; }
        ;;
    esac
  done
  cur_output="$out_dir_part/$out_name.$out_ext"
fi

body=$(pandoc -f gfm -t html "$input")

# Rewrite .md links to .html
if $rewrite_links; then
  body=$(echo "$body" | sed -E 's/(href="[^"]*\.)md(["#])/\1html\2/g')
fi

# Check if we need an output folder
use_folder=false
for s in ${styles[@]+"${styles[@]}"}; do
  val="${s#*:}"
  [[ "$s" == link:* && -f "$val" ]] && use_folder=true
done
for s in ${scripts[@]+"${scripts[@]}"}; do
  val="${s#*:}"
  [[ "$s" == link:* && -f "$val" ]] && use_folder=true
done

if $use_folder; then
  out_dir="${cur_output%.html}"
  mkdir -p "$out_dir"
  out_file="$out_dir/$(basename "$cur_output")"
else
  mkdir -p "$(dirname "$cur_output")"
  out_file="$cur_output"
fi

# Build style tags in order
style_html=""
for s in ${styles[@]+"${styles[@]}"}; do
  type="${s%%:*}"
  val="${s#*:}"
  if [[ "$type" == "inline" ]]; then
    [[ -f "$val" ]] || { echo "Error: stylesheet $val not found" >&2; exit 1; }
    style_html+="<style>$(cat "$val")</style>"
  else
    if [[ -f "$val" ]]; then
      css_name="$(basename "$val")"
      cp "$val" "$out_dir/$css_name"
      style_html+="<link rel=\"stylesheet\" href=\"$css_name\">"
    else
      style_html+="<link rel=\"stylesheet\" href=\"$val\">"
    fi
  fi
done

# Build script tags in order
script_tags=""
for s in ${scripts[@]+"${scripts[@]}"}; do
  type="${s%%:*}"
  val="${s#*:}"
  if [[ "$type" == "inline" ]]; then
    [[ -f "$val" ]] || { echo "Error: script $val not found" >&2; exit 1; }
    script_tags+="<script>$(cat "$val")</script>"
  else
    if [[ -f "$val" ]]; then
      js_name="$(basename "$val")"
      cp "$val" "$out_dir/$js_name"
      script_tags+="<script src=\"$js_name\"></script>"
    else
      script_tags+="<script src=\"$val\"></script>"
    fi
  fi
done

# PDF-specific styles
if [[ "$cur_output" == *.pdf ]] || [[ -n "$pdf_engine" ]]; then
  pdf_style="<style>@page{size:$page_size;margin:$page_margin;}body{max-width:none;margin:0;padding:0;}</style>"
  body_style=""
else
  pdf_style=""
  body_style=" style=\"max-width:800px;margin:auto;padding:2em;\""
fi

nav_data_tag=""
[[ -n "$nav_json" ]] && nav_data_tag="<script id=\"muck-nav-data\" type=\"application/json\">$nav_json</script>"

cat > "$out_file" <<EOF
<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
$style_html$pdf_style</head>
<body$body_style>
$body
$nav_data_tag$script_tags</body>
</html>
EOF

# PDF output
if [[ "$cur_output" == *.pdf ]] || [[ -n "$pdf_engine" ]]; then
  [[ -z "$pdf_engine" ]] && pdf_engine="weasyprint"
  pdf_out="${cur_output%.html}"
  [[ "$pdf_out" != *.pdf ]] && pdf_out="${pdf_out%.pdf}.pdf"
  tmp_html=$(mktemp "${TMPDIR:-/tmp}/muck.XXXXXX")
  mv "$tmp_html" "$tmp_html.html"
  tmp_html="$tmp_html.html"
  mv "$out_file" "$tmp_html"
  if [[ "$(uname)" == "Darwin" ]] && [[ -d /opt/homebrew/lib ]]; then
    export DYLD_LIBRARY_PATH="/opt/homebrew/lib${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}"
  fi
  "$pdf_engine" "$tmp_html" "$pdf_out"
  rm -f "$tmp_html"
  echo "Converted $input -> $pdf_out"
else
  echo "Converted $input -> $out_file"
fi

done
